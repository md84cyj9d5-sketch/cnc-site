# Пример переменных окружения для Telegram Bot API
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Добавляется автоматически после подключения Vercel Blob Store.
# Для локальной разработки укажите токен подключённого Blob-хранилища.
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
